# Database (Railway provides this automatically for the Postgres addon)
DATABASE_URL="postgresql://user:password@localhost:5432/fitai_db"

# Server
PORT=3001
NODE_ENV=development

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-random-32-byte-hex-string"

# Groq — get a free key at https://console.groq.com
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

# CORS — set to your Vercel frontend URL in production (e.g. https://fitai.vercel.app)
CLIENT_URL="http://localhost:5173"
